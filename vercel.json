{
  "rewrites": [
    {
      "source": "/services/:slug",
      "destination": "/services/:slug/index.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy/index.html"
    },
    {
      "source": "/medical-disclaimer",
      "destination": "/medical-disclaimer/index.html"
    },
    {
      "source": "/terms-conditions",
      "destination": "/terms-conditions/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}